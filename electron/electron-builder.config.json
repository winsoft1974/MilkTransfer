{
  "appId": "com.winsoft.milktransfer",
  "productName": "MilkTransfer",
  "directories": {
    "buildResources": "assets",
    "output": "dist_electron"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "extraResources": [
    {
      "from": "backend",
      "to": "backend",
      "filter": [
        "**/*"
      ]
    }
  ],
  "asar": true,
  "publish": null,
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "assets/appIcon.ico",
    "uninstallerIcon": "assets/appIcon.ico"
  },
  "win": {
    "target": "nsis",
    "icon": "assets/appIcon.ico"
  }
}